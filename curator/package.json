{
	"name": "svelte-app",
	"version": "0.0.39",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"docker": "docker build -t kangruixiang/curator:0.0.39 . && docker tag kangruixiang/curator:0.0.39 kangruixiang/curator:latest && docker push kangruixiang/curator:0.0.39 && docker push kangruixiang/curator:latest",
		"update": "pnpm up",
		"build": "vite build",
		"preview": "vite preview",
		"start": "vite build && vite preview --host",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.1",
		"@sveltejs/adapter-auto": "^6.1.1",
